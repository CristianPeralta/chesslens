# Chess.com username (no auth required — public API)
CHESSLENS_USERNAME=

# AI provider — LiteLLM model string
# Examples: claude-sonnet-4-6 | gpt-4o | gemini/gemini-2.5-pro | ollama/llama3
CHESSLENS_MODEL=claude-sonnet-4-6

# API keys (only needed for the model you choose)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Stockfish binary path (auto-detected if in PATH)
STOCKFISH_PATH=

# Database URL — SQLite (default, no setup needed)
# CHESSLENS_DATABASE_URL=sqlite:///chesslens.db

# Database URL — PostgreSQL (use with docker-compose)
CHESSLENS_DATABASE_URL=postgresql+psycopg://chesslens:chesslens@localhost:5432/chesslens

# Report output directory (default: ./reports)
REPORTS_DIR=./reports
