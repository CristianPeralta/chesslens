# ── chesslens deploy configuration ─────────────────────────────
# Copy to `.env` and fill in. `.env` is git-ignored.
# TLS/reverse proxy is handled by host nginx, not by this stack.

# REQUIRED — no default. Generate one: `openssl rand -hex 32`
CHESSLENS_JWT_SECRET=

# AI narrative provider (LiteLLM). Default: Google Gemini.
CHESSLENS_MODEL=gemini/gemini-2.5-pro
GEMINI_API_KEY=

# To swap providers, change CHESSLENS_MODEL and set the matching key:
#   CHESSLENS_MODEL=claude-sonnet-4-6        + ANTHROPIC_API_KEY=...
#   CHESSLENS_MODEL=gpt-4o                   + OPENAI_API_KEY=...
#   CHESSLENS_MODEL=ollama/llama3            (local, no key)
